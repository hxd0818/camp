# CAMP Environment Configuration
# Copy this file to .env and update values for your environment

# --- Application ---
APP_NAME=CAMP API
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cdata:cdata_dev_password@localhost:5432/cdata

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
SECRET_KEY=change-me-in-production-strong-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# --- LLM / AI (for contract import) ---
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=qwen-plus

# --- Multi-tenant ---
DEFAULT_TENANT_ID=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
